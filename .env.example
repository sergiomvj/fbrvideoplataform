# ============================================
# Synkra - Motor Editorial de Videos Templated
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real credentials
# ============================================

# --------------------------------------------
# Frontend (Next.js)
# --------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:80/api
BACKEND_URL=http://backend:8000

# --------------------------------------------
# Session (iron-session)
# --------------------------------------------
# Must be 32+ characters. Generate with: openssl rand -base64 32
SESSION_SECRET=

# --------------------------------------------
# Backend (FastAPI)
# --------------------------------------------
# For Docker Compose use: postgresql+asyncpg://synkra:synkra@postgres:5432/synkra
# For local dev use:      postgresql+asyncpg://synkra:synkra@localhost:5432/synkra
DATABASE_URL=postgresql+asyncpg://synkra:synkra@postgres:5432/synkra
REDIS_URL=redis://redis:6379/0
# Internal token for backend-to-backend auth. Generate with: openssl rand -hex 32
BACKEND_INTERNAL_TOKEN=
ALLOWED_ORIGINS=["http://localhost:80"]
ENABLE_DOCS=false

# --------------------------------------------
# PostgreSQL
# --------------------------------------------
POSTGRES_USER=synkra
POSTGRES_PASSWORD=synkra
POSTGRES_DB=synkra

# --------------------------------------------
# Redis
# --------------------------------------------
# No extra config needed; uses default port internally

# --------------------------------------------
# n8n (Workflow Automation)
# --------------------------------------------
N8N_USER=admin
N8N_PASSWORD=changeme

# --------------------------------------------
# Grafana
# --------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme

# --------------------------------------------
# Monitoring
# --------------------------------------------
SENTRY_DSN=

# --------------------------------------------
# External Integrations (future stories)
# --------------------------------------------
HEYGEN_API_KEY=
LLM_PROVIDER=

# --------------------------------------------
# AIOX Core
# --------------------------------------------
NODE_ENV=development
AIOX_VERSION=2.2.0
